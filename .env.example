# ShellMate configuration

# Server
SHELLMATE_HOST=127.0.0.1
SHELLMATE_PORT=8765

# Claude API (optional — leave blank to disable)
ANTHROPIC_API_KEY=

# Ollama (optional — defaults shown)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# Default AI backend: "claude" or "ollama"
DEFAULT_AI_BACKEND=ollama

# Serial port defaults (Windows)
DEFAULT_SERIAL_PORT=COM3
DEFAULT_BAUD_RATE=9600

# Chroma vector DB (optional — leave CHROMA_URL blank to disable)
# When set, ShellMate queries this collection for design-guideline snippets
# and injects matches into the AI prompt on every chat.
CHROMA_URL=
CHROMA_COLLECTION=design_guidelines
